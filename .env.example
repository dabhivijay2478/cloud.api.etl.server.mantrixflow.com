# ETL server config — loaded automatically at startup from apps/new-etl/.env
# Copy this file to .env and adjust as needed.
#
# Tap and target executables (no hardcoded names in code)
# Set these or use TAP_REGISTRY / TARGET_REGISTRY JSON for multiple types
TAP_POSTGRES=tap-postgres
TARGET_POSTGRES=target-postgres

# SSL is driven by each connection's `ssl` field (bool/string/dict) in the database.
# Host-based SSL inference via SSL_CLOUD_HOST_SUFFIXES is deprecated and not used.
# SSL_CLOUD_HOST_SUFFIXES is kept for backwards compatibility only and has no effect.
# SSL_CLOUD_HOST_SUFFIXES=

# Concurrency
MAX_CONCURRENT_RUNS=20
MAX_TAPS_PER_SOURCE=3
