# ETL server config — copy to .env and adjust
# MANTrixFlow ETL — dlt sql_database + pg_replication

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ENCRYPTION_KEY=your-32-byte-hex-fernet-key
CALLBACK_URL=https://cloud.api.mantrixflow.com/etl/callback
ETL_INTERNAL_TOKEN=your-random-secret-token
CALLBACK_TOKEN=your-callback-token
MAX_CONCURRENT_RUNS=20
DEFAULT_SYNC_TIMEOUT_SECONDS=300
LOG_LEVEL=INFO
PORT=8000
