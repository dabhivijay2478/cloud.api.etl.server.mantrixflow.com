# Python ETL Service Configuration
PORT=8001

# Supabase JWT validation (optional - for production)
# SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# Database connection strings (required for creating data sources in Supabase)
# Get this from your Supabase project settings > Database > Connection string
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Logging
LOG_LEVEL=INFO
