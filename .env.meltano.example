# Meltano Bidirectional Sync: Postgres ↔ MongoDB
#
# DYNAMIC MODE (recommended): Connections come from the database. The API
# fetches them from data_source_connections and passes to POST /run-meltano-pipeline.
# No env vars needed for pipeline execution.
#
# STATIC MODE (for meltano CLI): Set these when using meltano run directly.
# Copy to .env: cp .env.meltano.example .env

# Postgres connection (used by tap-postgres and target-postgres)
POSTGRES_URL=postgresql://user:password@localhost:5432/mydb

# MongoDB connection (used by tap-mongodb and target-mongodb)
MONGODB_URI=mongodb://user:password@localhost:27017
MONGODB_DATABASE=mydb
